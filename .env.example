DATABASE_URL="postgresql://user:password@localhost:5432/trading_coach"
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_BOT_USERNAME="your_bot_username"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_WEBHOOK_SECRET="your_webhook_secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
ANTHROPIC_API_KEY="your_anthropic_api_key"
CRON_SECRET="your_cron_secret"

# Tradovate OAuth — required for the one-click "Connect Tradovate" flow.
# Obtain a client_id and client_secret from the Tradovate partner portal.
# TRADOVATE_REDIRECT_URI defaults to NEXT_PUBLIC_APP_URL + /api/auth/tradovate/callback.
# Without these vars the connection page falls back to manual webhook setup.
TRADOVATE_CLIENT_ID="your_tradovate_client_id"
TRADOVATE_CLIENT_SECRET="your_tradovate_client_secret"

# Google OAuth — required for "Continue with Google" on login/signup.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the authorized redirect URI to: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"