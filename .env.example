DATABASE_URL="postgresql://user:password@localhost:5432/trading_coach"
TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_BOT_USERNAME="your_bot_username"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_WEBHOOK_SECRET="your_webhook_secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
ANTHROPIC_API_KEY="your_anthropic_api_key"
CRON_SECRET="your_cron_secret"

# ── Tradovate OAuth — read-only foundation ────────────────────────────────────
# All three required vars below must be set before the OAuth flow will
# start. If any one is missing, /accounts/connect/tradovate displays a
# "not configured yet" state and Manual Mode remains the fallback.
# Obtain client_id and client_secret from the Tradovate partner portal.
TRADOVATE_CLIENT_ID="your_tradovate_client_id"
TRADOVATE_CLIENT_SECRET="your_tradovate_client_secret"

# Base64-encoded 32-byte master key used to encrypt OAuth tokens at rest
# (AES-256-GCM). Generate with:
#   openssl rand -base64 32
# The decoded length must be exactly 32 bytes — the runtime rejects any
# other size with KEY_LENGTH. Never commit a real key.
TRADOVATE_TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Required in production: must match exactly what is registered in the
# Tradovate OAuth app. Set to your production domain:
#   https://guardrail-trade.com/api/auth/tradovate/callback
# Leave empty in local dev — the routes derive it from the request origin.
TRADOVATE_REDIRECT_URI=""

# Optional URL overrides — defaults point to Tradovate's hosted endpoints.
# Override per env (live vs demo) for sandbox or custom deployments.
# TRADOVATE_AUTH_URL_LIVE="https://live.tradovate.com/oauth/authorize"
# TRADOVATE_AUTH_URL_DEMO="https://demo.tradovate.com/oauth/authorize"
# TRADOVATE_TOKEN_URL_LIVE="https://live.tradovate.com/oauth/token"
# TRADOVATE_TOKEN_URL_DEMO="https://demo.tradovate.com/oauth/token"
# TRADOVATE_API_BASE_URL_LIVE="https://live.tradovateapi.com/v1"
# TRADOVATE_API_BASE_URL_DEMO="https://demo.tradovateapi.com/v1"

# Google OAuth — required for "Continue with Google" on login/signup.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Set the authorized redirect URI to: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Set BILLING_ENABLED=true to activate the subscription gate.
# While false, all onboarding-complete users have coach access (no paywall).
BILLING_ENABLED=false

# Stripe API keys — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# The recurring monthly price ID from your Stripe product catalog.
STRIPE_PRICE_ID="price_..."

# Webhook signing secret — from https://dashboard.stripe.com/webhooks
# Point the webhook to: {NEXT_PUBLIC_APP_URL}/api/billing/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Admin override ────────────────────────────────────────────────────────────
# Comma-separated emails that always bypass the billing gate.
# noamyaacob12@gmail.com is permanently hardcoded; add extras here.
ADMIN_EMAILS=""