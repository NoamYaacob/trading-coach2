# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string — required. Used by Prisma at startup.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/trading_coach

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Token from @BotFather — required for Telegram coaching to work.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUVwxyz

# Bot username without the @ prefix.
# Used server-side to generate invite links (/api/telegram/link-token).
# Set one of these — server-side preferred over public.
TELEGRAM_BOT_USERNAME=your_bot_username
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username   # fallback if needed client-side

# ── Runtime ────────────────────────────────────────────────────────────────────
# Must be "production" in deployed environments.
# Controls: secure cookie flag on sessions, Prisma log level.
NODE_ENV=production
