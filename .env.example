DATABASE_URL="postgresql://user:password@localhost:5432/trading_coach"

APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

ANTHROPIC_API_KEY="your_anthropic_api_key"
CRON_SECRET="your_cron_secret"

TELEGRAM_BOT_TOKEN="your_bot_token"
TELEGRAM_BOT_USERNAME="your_bot_username"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_WEBHOOK_SECRET="your_webhook_secret"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Required for "Continue with Google" on login/signup.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
#
# Production:
#   https://guardrail-trade.com/api/auth/google/callback
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── Tradovate OAuth — read-only foundation ────────────────────────────────────
# Required before the OAuth flow can start.
# Obtain client_id and client_secret from the Tradovate partner portal.
TRADOVATE_CLIENT_ID="your_tradovate_client_id"
TRADOVATE_CLIENT_SECRET="your_tradovate_client_secret"

# Base64-encoded 32-byte master key used to encrypt OAuth tokens at rest
# with AES-256-GCM.
# Generate with:
#   openssl rand -base64 32
# Never commit a real key.
TRADOVATE_TOKEN_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Explicit redirect URI.
# Local:
TRADOVATE_REDIRECT_URI="http://localhost:3000/api/auth/tradovate/callback"

# Production:
#   TRADOVATE_REDIRECT_URI="https://guardrail-trade.com/api/auth/tradovate/callback"

# Optional URL overrides. Defaults are verified from the official Tradovate
# OAuth example (https://github.com/tradovate/example-api-oauth):
#
#   Authorization (same path /oauth; -d suffix = demo environment):
# TRADOVATE_AUTH_URL_LIVE="https://trader.tradovate.com/oauth"
# TRADOVATE_AUTH_URL_DEMO="https://trader-d.tradovate.com/oauth"
#
#   Token exchange (path is /auth/oauthtoken — no /v1 prefix):
# TRADOVATE_TOKEN_URL_LIVE="https://live-api.tradovate.com/auth/oauthtoken"
# TRADOVATE_TOKEN_URL_DEMO="https://live-api-d.tradovate.com/auth/oauthtoken"
#
#   REST API base (read pipeline, separate from OAuth):
# TRADOVATE_API_BASE_URL_LIVE="https://live.tradovateapi.com/v1"
# TRADOVATE_API_BASE_URL_DEMO="https://demo.tradovateapi.com/v1"

# ── Billing / Stripe ──────────────────────────────────────────────────────────
# Set BILLING_ENABLED=true to activate the subscription gate.
# While false, all onboarding-complete users have coach access.
BILLING_ENABLED=false

STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Webhook endpoint:
#   {NEXT_PUBLIC_APP_URL}/api/billing/webhook

# ── Admin override ────────────────────────────────────────────────────────────
# Comma-separated emails that always bypass the billing gate.
# noamyaacob12@gmail.com is permanently hardcoded; add extras here.
ADMIN_EMAILS=""
