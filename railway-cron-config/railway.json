{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "node -e \"const u=new URL('/api/cron/renew-tradovate-tokens',process.env.APP_URL).href;const s=process.env.CRON_SECRET;fetch(u,{method:'POST',headers:{'x-cron-secret':s,'content-type':'application/json'}}).then(async r=>{const b=await r.text();console.log(r.status,b);if(!r.ok)process.exit(1);}).catch(e=>{console.error(e);process.exit(1);});\"",
    "cronSchedule": "*/10 * * * *",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
